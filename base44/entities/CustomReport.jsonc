{
  "name": "CustomReport",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "title": "\u0627\u0633\u0645 \u0627\u0644\u062a\u0642\u0631\u064a\u0631"
    },
    "description": {
      "type": "string",
      "title": "\u0627\u0644\u0648\u0635\u0641"
    },
    "entity": {
      "type": "string",
      "enum": [
        "Invoice",
        "Voucher",
        "StockTransfer",
        "Product",
        "Account",
        "Employee",
        "SalaryRecord",
        "CostEntry"
      ],
      "title": "\u0627\u0644\u062c\u062f\u0648\u0644"
    },
    "fields": {
      "type": "array",
      "title": "\u0627\u0644\u062d\u0642\u0648\u0644 \u0627\u0644\u0645\u062e\u062a\u0627\u0631\u0629",
      "items": {
        "type": "string"
      }
    },
    "filters": {
      "type": "array",
      "title": "\u0627\u0644\u0641\u0644\u0627\u062a\u0631",
      "items": {
        "type": "object",
        "properties": {
          "field": {
            "type": "string"
          },
          "operator": {
            "type": "string"
          },
          "value": {
            "type": "string"
          }
        }
      }
    },
    "sort_by": {
      "type": "string",
      "title": "\u0627\u0644\u062a\u0631\u062a\u064a\u0628 \u062d\u0633\u0628"
    },
    "sort_dir": {
      "type": "string",
      "enum": [
        "\u062a\u0635\u0627\u0639\u062f\u064a",
        "\u062a\u0646\u0627\u0632\u0644\u064a"
      ],
      "title": "\u0627\u062a\u062c\u0627\u0647 \u0627\u0644\u062a\u0631\u062a\u064a\u0628"
    },
    "is_favorite": {
      "type": "boolean",
      "default": false,
      "title": "\u0645\u0641\u0636\u0644"
    }
  },
  "required": [
    "name",
    "entity"
  ],
  "rls": {
    "create": {
      "created_by_id": "{{user.id}}"
    },
    "read": {
      "$or": [
        {
          "created_by_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "created_by_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "created_by_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}