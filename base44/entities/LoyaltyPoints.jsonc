{
  "name": "LoyaltyPoints",
  "type": "object",
  "properties": {
    "client_id": {
      "type": "string",
      "title": "\u0645\u0639\u0631\u0651\u0641 \u0627\u0644\u0639\u0645\u064a\u0644"
    },
    "client_name": {
      "type": "string",
      "title": "\u0627\u0633\u0645 \u0627\u0644\u0639\u0645\u064a\u0644"
    },
    "client_phone": {
      "type": "string",
      "title": "\u0647\u0627\u062a\u0641 \u0627\u0644\u0639\u0645\u064a\u0644"
    },
    "total_points": {
      "type": "number",
      "title": "\u0625\u062c\u0645\u0627\u0644\u064a \u0627\u0644\u0646\u0642\u0627\u0637",
      "default": 0
    },
    "used_points": {
      "type": "number",
      "title": "\u0627\u0644\u0646\u0642\u0627\u0637 \u0627\u0644\u0645\u0633\u062a\u062e\u062f\u0645\u0629",
      "default": 0
    },
    "available_points": {
      "type": "number",
      "title": "\u0627\u0644\u0646\u0642\u0627\u0637 \u0627\u0644\u0645\u062a\u0627\u062d\u0629",
      "default": 0
    },
    "tier": {
      "type": "string",
      "enum": [
        "\u0628\u0631\u0648\u0646\u0632\u064a",
        "\u0641\u0636\u064a",
        "\u0630\u0647\u0628\u064a",
        "\u0628\u0644\u0627\u062a\u064a\u0646\u064a"
      ],
      "default": "\u0628\u0631\u0648\u0646\u0632\u064a",
      "title": "\u0627\u0644\u0645\u0633\u062a\u0648\u0649"
    },
    "notes": {
      "type": "string",
      "title": "\u0645\u0644\u0627\u062d\u0638\u0627\u062a"
    }
  },
  "required": [
    "client_name"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "created_by_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "read": {
      "$or": [
        {
          "created_by_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "role": "pos_cashier"
          }
        },
        {
          "user_condition": {
            "role": "branch_manager"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "created_by_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "role": "pos_cashier"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "created_by_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}