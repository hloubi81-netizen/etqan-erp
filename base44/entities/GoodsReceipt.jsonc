{
  "name": "GoodsReceipt",
  "type": "object",
  "properties": {
    "receipt_number": {
      "type": "string",
      "title": "\u0631\u0642\u0645 \u0637\u0644\u0628 \u0627\u0644\u0627\u0633\u062a\u0644\u0627\u0645"
    },
    "purchase_order_id": {
      "type": "string",
      "title": "\u0623\u0645\u0631 \u0627\u0644\u0634\u0631\u0627\u0621 \u0627\u0644\u0645\u0631\u062a\u0628\u0637"
    },
    "purchase_order_number": {
      "type": "string",
      "title": "\u0631\u0642\u0645 \u0623\u0645\u0631 \u0627\u0644\u0634\u0631\u0627\u0621"
    },
    "date": {
      "type": "string",
      "format": "date",
      "title": "\u062a\u0627\u0631\u064a\u062e \u0627\u0644\u0627\u0633\u062a\u0644\u0627\u0645"
    },
    "supplier_name": {
      "type": "string",
      "title": "\u0627\u0633\u0645 \u0627\u0644\u0645\u0648\u0631\u062f"
    },
    "warehouse_id": {
      "type": "string",
      "title": "\u0627\u0644\u0645\u0633\u062a\u0648\u062f\u0639"
    },
    "warehouse_name": {
      "type": "string",
      "title": "\u0627\u0633\u0645 \u0627\u0644\u0645\u0633\u062a\u0648\u062f\u0639"
    },
    "items": {
      "type": "array",
      "title": "\u0627\u0644\u0628\u0646\u0648\u062f \u0627\u0644\u0645\u0633\u062a\u0644\u0645\u0629",
      "items": {
        "type": "object",
        "properties": {
          "product_id": {
            "type": "string"
          },
          "product_name": {
            "type": "string"
          },
          "ordered_quantity": {
            "type": "number"
          },
          "received_quantity": {
            "type": "number"
          },
          "unit": {
            "type": "string"
          },
          "price": {
            "type": "number"
          },
          "total": {
            "type": "number"
          },
          "condition": {
            "type": "string",
            "enum": [
              "\u0645\u0637\u0627\u0628\u0642",
              "\u062a\u0627\u0644\u0641 \u062c\u0632\u0626\u064a",
              "\u0645\u0631\u0641\u0648\u0636"
            ]
          }
        }
      }
    },
    "subtotal": {
      "type": "number",
      "title": "\u0627\u0644\u0645\u062c\u0645\u0648\u0639"
    },
    "total": {
      "type": "number",
      "title": "\u0627\u0644\u0625\u062c\u0645\u0627\u0644\u064a"
    },
    "linked_invoice_id": {
      "type": "string",
      "title": "\u0641\u0627\u062a\u0648\u0631\u0629 \u0627\u0644\u0645\u0648\u0631\u062f \u0627\u0644\u0645\u0631\u062a\u0628\u0637\u0629"
    },
    "linked_invoice_number": {
      "type": "string",
      "title": "\u0631\u0642\u0645 \u0641\u0627\u062a\u0648\u0631\u0629 \u0627\u0644\u0645\u0648\u0631\u062f"
    },
    "status": {
      "type": "string",
      "enum": [
        "\u0645\u0633\u0648\u062f\u0629",
        "\u0645\u0633\u062a\u0644\u0645",
        "\u0645\u0637\u0627\u0628\u0642",
        "\u0628\u0647 \u0641\u0631\u0648\u0642\u0627\u062a",
        "\u0645\u0644\u063a\u0649"
      ],
      "default": "\u0645\u0633\u0648\u062f\u0629",
      "title": "\u0627\u0644\u062d\u0627\u0644\u0629"
    },
    "match_status": {
      "type": "string",
      "enum": [
        "\u063a\u064a\u0631 \u0645\u062d\u062f\u062f",
        "\u0645\u0637\u0627\u0628\u0642",
        "\u0641\u0631\u0642 \u0641\u064a \u0627\u0644\u0643\u0645\u064a\u0629",
        "\u0641\u0631\u0642 \u0641\u064a \u0627\u0644\u0633\u0639\u0631",
        "\u0641\u0631\u0642 \u0645\u0632\u062f\u0648\u062c"
      ],
      "default": "\u063a\u064a\u0631 \u0645\u062d\u062f\u062f",
      "title": "\u062d\u0627\u0644\u0629 \u0627\u0644\u0645\u0637\u0627\u0628\u0642\u0629"
    },
    "notes": {
      "type": "string",
      "title": "\u0645\u0644\u0627\u062d\u0638\u0627\u062a"
    }
  },
  "required": [
    "receipt_number",
    "purchase_order_id",
    "date"
  ]
}