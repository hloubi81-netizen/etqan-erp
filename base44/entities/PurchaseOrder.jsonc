{
  "name": "PurchaseOrder",
  "type": "object",
  "properties": {
    "order_number": {
      "type": "string",
      "title": "\u0631\u0642\u0645 \u0627\u0644\u0623\u0645\u0631"
    },
    "type": {
      "type": "string",
      "enum": [
        "\u0623\u0645\u0631 \u0634\u0631\u0627\u0621",
        "\u0639\u0631\u0636 \u0633\u0639\u0631 \u0645\u0628\u064a\u0639\u0627\u062a"
      ],
      "title": "\u0627\u0644\u0646\u0648\u0639"
    },
    "date": {
      "type": "string",
      "format": "date",
      "title": "\u0627\u0644\u062a\u0627\u0631\u064a\u062e"
    },
    "client_account_id": {
      "type": "string",
      "title": "\u062d\u0633\u0627\u0628 \u0627\u0644\u0639\u0645\u064a\u0644/\u0627\u0644\u0645\u0648\u0631\u062f"
    },
    "client_name": {
      "type": "string",
      "title": "\u0627\u0633\u0645 \u0627\u0644\u0639\u0645\u064a\u0644/\u0627\u0644\u0645\u0648\u0631\u062f"
    },
    "warehouse_id": {
      "type": "string",
      "title": "\u0627\u0644\u0645\u0633\u062a\u0648\u062f\u0639"
    },
    "warehouse_name": {
      "type": "string",
      "title": "\u0627\u0633\u0645 \u0627\u0644\u0645\u0633\u062a\u0648\u062f\u0639"
    },
    "items": {
      "type": "array",
      "title": "\u0627\u0644\u0628\u0646\u0648\u062f",
      "items": {
        "type": "object",
        "properties": {
          "product_id": {
            "type": "string"
          },
          "product_name": {
            "type": "string"
          },
          "quantity": {
            "type": "number"
          },
          "unit": {
            "type": "string"
          },
          "price": {
            "type": "number"
          },
          "total": {
            "type": "number"
          },
          "received_quantity": {
            "type": "number"
          }
        }
      }
    },
    "subtotal": {
      "type": "number",
      "title": "\u0627\u0644\u0645\u062c\u0645\u0648\u0639"
    },
    "discount_value": {
      "type": "number",
      "title": "\u0642\u064a\u0645\u0629 \u0627\u0644\u062e\u0635\u0645"
    },
    "tax_amount": {
      "type": "number",
      "title": "\u0627\u0644\u0636\u0631\u064a\u0628\u0629"
    },
    "total": {
      "type": "number",
      "title": "\u0627\u0644\u0625\u062c\u0645\u0627\u0644\u064a"
    },
    "expected_date": {
      "type": "string",
      "format": "date",
      "title": "\u062a\u0627\u0631\u064a\u062e \u0627\u0644\u0627\u0633\u062a\u0644\u0627\u0645 \u0627\u0644\u0645\u062a\u0648\u0642\u0639"
    },
    "subscription_id": {
      "type": "string",
      "title": "\u0645\u0639\u0631\u0641 \u0627\u0644\u0627\u0634\u062a\u0631\u0627\u0643"
    },
    "notes": {
      "type": "string",
      "title": "\u0645\u0644\u0627\u062d\u0638\u0627\u062a"
    },
    "status": {
      "type": "string",
      "enum": [
        "\u0645\u0633\u0648\u062f\u0629",
        "\u0645\u0639\u062a\u0645\u062f",
        "\u0645\u0633\u062a\u0644\u0645 \u062c\u0632\u0626\u064a\u0627\u064b",
        "\u0645\u0633\u062a\u0644\u0645 \u0643\u0644\u064a\u0627\u064b",
        "\u0645\u0644\u063a\u0649"
      ],
      "default": "\u0645\u0633\u0648\u062f\u0629",
      "title": "\u0627\u0644\u062d\u0627\u0644\u0629"
    },
    "linked_invoice_id": {
      "type": "string",
      "title": "\u0627\u0644\u0641\u0627\u062a\u0648\u0631\u0629 \u0627\u0644\u0645\u0631\u062a\u0628\u0637\u0629"
    },
    "linked_invoice_number": {
      "type": "string",
      "title": "\u0631\u0642\u0645 \u0627\u0644\u0641\u0627\u062a\u0648\u0631\u0629 \u0627\u0644\u0645\u0631\u062a\u0628\u0637\u0629"
    },
    "receipt_ids": {
      "type": "array",
      "title": "\u0637\u0644\u0628\u0627\u062a \u0627\u0644\u0627\u0633\u062a\u0644\u0627\u0645 \u0627\u0644\u0645\u0631\u062a\u0628\u0637\u0629",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "order_number",
    "type",
    "date"
  ],
  "rls": {
    "create": {
      "data.subscription_id": "{{user.subscription_id}}"
    },
    "read": {
      "data.subscription_id": "{{user.subscription_id}}"
    },
    "update": {
      "data.subscription_id": "{{user.subscription_id}}"
    },
    "delete": {
      "$and": [
        {
          "data.subscription_id": "{{user.subscription_id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}