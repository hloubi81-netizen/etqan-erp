{
  "name": "Budget",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "title": "\u0627\u0633\u0645 \u0627\u0644\u0645\u064a\u0632\u0627\u0646\u064a\u0629"
    },
    "year": {
      "type": "string",
      "title": "\u0627\u0644\u0633\u0646\u0629"
    },
    "period_type": {
      "type": "string",
      "enum": [
        "\u0633\u0646\u0648\u064a\u0629",
        "\u0631\u0628\u0639 \u0633\u0646\u0648\u064a\u0629",
        "\u0634\u0647\u0631\u064a\u0629"
      ],
      "title": "\u0646\u0648\u0639 \u0627\u0644\u0641\u062a\u0631\u0629"
    },
    "period_label": {
      "type": "string",
      "title": "\u0627\u0644\u0641\u062a\u0631\u0629 (\u0645\u062b\u0644: Q1 2025)"
    },
    "cost_center_id": {
      "type": "string",
      "title": "\u0645\u0631\u0643\u0632 \u0627\u0644\u062a\u0643\u0644\u0641\u0629"
    },
    "cost_center_name": {
      "type": "string",
      "title": "\u0627\u0633\u0645 \u0645\u0631\u0643\u0632 \u0627\u0644\u062a\u0643\u0644\u0641\u0629"
    },
    "items": {
      "type": "array",
      "title": "\u0628\u0646\u0648\u062f \u0627\u0644\u0645\u064a\u0632\u0627\u0646\u064a\u0629",
      "items": {
        "type": "object",
        "properties": {
          "account_id": {
            "type": "string"
          },
          "account_name": {
            "type": "string"
          },
          "budgeted_amount": {
            "type": "number"
          },
          "actual_amount": {
            "type": "number"
          },
          "variance": {
            "type": "number"
          }
        }
      }
    },
    "total_budgeted": {
      "type": "number",
      "title": "\u0625\u062c\u0645\u0627\u0644\u064a \u0627\u0644\u0645\u064a\u0632\u0627\u0646\u064a\u0629"
    },
    "total_actual": {
      "type": "number",
      "title": "\u0627\u0644\u0641\u0639\u0644\u064a"
    },
    "notes": {
      "type": "string",
      "title": "\u0645\u0644\u0627\u062d\u0638\u0627\u062a"
    },
    "status": {
      "type": "string",
      "enum": [
        "\u0645\u0633\u0648\u062f\u0629",
        "\u0645\u0639\u062a\u0645\u062f\u0629",
        "\u0645\u063a\u0644\u0642\u0629"
      ],
      "default": "\u0645\u0633\u0648\u062f\u0629",
      "title": "\u0627\u0644\u062d\u0627\u0644\u0629"
    }
  },
  "required": [
    "name",
    "year"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "created_by_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "role": "accountant"
          }
        }
      ]
    },
    "read": {
      "$or": [
        {
          "created_by_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "role": "accountant"
          }
        },
        {
          "user_condition": {
            "role": "costs_manager"
          }
        },
        {
          "user_condition": {
            "role": "viewer"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "created_by_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "role": "accountant"
          }
        }
      ]
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}