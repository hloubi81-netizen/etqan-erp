{
  "name": "PointsSettings",
  "type": "object",
  "properties": {
    "points_per_currency": {
      "type": "number",
      "title": "\u0646\u0642\u0627\u0637 \u0644\u0643\u0644 \u0648\u062d\u062f\u0629 \u0639\u0645\u0644\u0629",
      "default": 1
    },
    "currency_per_point": {
      "type": "number",
      "title": "\u0642\u064a\u0645\u0629 \u0627\u0644\u0646\u0642\u0637\u0629 \u0627\u0644\u0648\u0627\u062d\u062f\u0629 \u0628\u0627\u0644\u0639\u0645\u0644\u0629",
      "default": 0.1
    },
    "min_redeem_points": {
      "type": "number",
      "title": "\u0627\u0644\u062d\u062f \u0627\u0644\u0623\u062f\u0646\u0649 \u0644\u0644\u0627\u0633\u062a\u0631\u062f\u0627\u062f",
      "default": 100
    },
    "silver_threshold": {
      "type": "number",
      "title": "\u062d\u062f \u0627\u0644\u0645\u0633\u062a\u0648\u0649 \u0627\u0644\u0641\u0636\u064a (\u0646\u0642\u0637\u0629)",
      "default": 500
    },
    "gold_threshold": {
      "type": "number",
      "title": "\u062d\u062f \u0627\u0644\u0645\u0633\u062a\u0648\u0649 \u0627\u0644\u0630\u0647\u0628\u064a (\u0646\u0642\u0637\u0629)",
      "default": 1500
    },
    "platinum_threshold": {
      "type": "number",
      "title": "\u062d\u062f \u0627\u0644\u0645\u0633\u062a\u0648\u0649 \u0627\u0644\u0628\u0644\u0627\u062a\u064a\u0646\u064a (\u0646\u0642\u0637\u0629)",
      "default": 5000
    },
    "silver_discount": {
      "type": "number",
      "title": "\u062e\u0635\u0645 \u0627\u0644\u0645\u0633\u062a\u0648\u0649 \u0627\u0644\u0641\u0636\u064a (%)",
      "default": 0
    },
    "gold_discount": {
      "type": "number",
      "title": "\u062e\u0635\u0645 \u0627\u0644\u0645\u0633\u062a\u0648\u0649 \u0627\u0644\u0630\u0647\u0628\u064a (%)",
      "default": 0
    },
    "platinum_discount": {
      "type": "number",
      "title": "\u062e\u0635\u0645 \u0627\u0644\u0645\u0633\u062a\u0648\u0649 \u0627\u0644\u0628\u0644\u0627\u062a\u064a\u0646\u064a (%)",
      "default": 0
    },
    "enable_loyalty": {
      "type": "boolean",
      "default": true,
      "title": "\u062a\u0641\u0639\u064a\u0644 \u0646\u0638\u0627\u0645 \u0627\u0644\u0648\u0644\u0627\u0621"
    },
    "enable_promotions": {
      "type": "boolean",
      "default": true,
      "title": "\u062a\u0641\u0639\u064a\u0644 \u0627\u0644\u0639\u0631\u0648\u0636"
    },
    "subscription_id": {
      "type": "string",
      "title": "\u0645\u0639\u0631\u0641 \u0627\u0644\u0627\u0634\u062a\u0631\u0627\u0643"
    },
    "description": {
      "type": "string",
      "title": "\u0627\u0644\u0648\u0635\u0641",
      "maxLength": 1000
    }
  },
  "required": [],
  "rls": {
    "create": {
      "data.subscription_id": "{{user.subscription_id}}"
    },
    "read": {
      "data.subscription_id": "{{user.subscription_id}}"
    },
    "update": {
      "data.subscription_id": "{{user.subscription_id}}"
    },
    "delete": {
      "$and": [
        {
          "data.subscription_id": "{{user.subscription_id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}