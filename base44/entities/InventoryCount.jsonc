{
  "name": "InventoryCount",
  "type": "object",
  "properties": {
    "count_number": {
      "type": "string",
      "title": "\u0631\u0642\u0645 \u0645\u062d\u0636\u0631 \u0627\u0644\u062c\u0631\u062f"
    },
    "date": {
      "type": "string",
      "format": "date",
      "title": "\u0627\u0644\u062a\u0627\u0631\u064a\u062e"
    },
    "warehouse_id": {
      "type": "string",
      "title": "\u0627\u0644\u0645\u0633\u062a\u0648\u062f\u0639"
    },
    "warehouse_name": {
      "type": "string",
      "title": "\u0627\u0633\u0645 \u0627\u0644\u0645\u0633\u062a\u0648\u062f\u0639"
    },
    "type": {
      "type": "string",
      "enum": [
        "\u0645\u062d\u0636\u0631 \u062c\u0631\u062f",
        "\u062a\u0633\u0648\u064a\u0629 \u062c\u0631\u062f\u064a\u0629"
      ],
      "title": "\u0627\u0644\u0646\u0648\u0639"
    },
    "items": {
      "type": "array",
      "title": "\u0627\u0644\u0623\u0635\u0646\u0627\u0641",
      "items": {
        "type": "object",
        "properties": {
          "product_id": {
            "type": "string"
          },
          "product_name": {
            "type": "string"
          },
          "book_quantity": {
            "type": "number"
          },
          "actual_quantity": {
            "type": "number"
          },
          "surplus": {
            "type": "number"
          },
          "deficit": {
            "type": "number"
          }
        }
      }
    },
    "subscription_id": {
      "type": "string",
      "title": "\u0645\u0639\u0631\u0641 \u0627\u0644\u0627\u0634\u062a\u0631\u0627\u0643"
    },
    "notes": {
      "type": "string",
      "title": "\u0645\u0644\u0627\u062d\u0638\u0627\u062a"
    },
    "status": {
      "type": "string",
      "enum": [
        "\u0645\u0633\u0648\u062f\u0629",
        "\u0645\u0639\u062a\u0645\u062f"
      ],
      "title": "\u0627\u0644\u062d\u0627\u0644\u0629"
    }
  },
  "required": [
    "count_number",
    "date",
    "warehouse_id"
  ],
  "rls": {
    "create": {
      "data.subscription_id": "{{user.subscription_id}}"
    },
    "read": {
      "data.subscription_id": "{{user.subscription_id}}"
    },
    "update": {
      "data.subscription_id": "{{user.subscription_id}}"
    },
    "delete": {
      "$and": [
        {
          "data.subscription_id": "{{user.subscription_id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}