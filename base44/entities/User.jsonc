{
  "name": "User",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "enum": [
        "admin",
        "user",
        "accountant",
        "inventory",
        "costs_manager",
        "branch_manager",
        "viewer"
      ],
      "title": "\u0627\u0644\u062f\u0648\u0631"
    },
    "branch_id": {
      "type": "string",
      "title": "\u0627\u0644\u0641\u0631\u0639"
    },
    "branch_name": {
      "type": "string",
      "title": "\u0627\u0633\u0645 \u0627\u0644\u0641\u0631\u0639"
    },
    "department": {
      "type": "string",
      "title": "\u0627\u0644\u0642\u0633\u0645 / \u0627\u0644\u0648\u0638\u064a\u0641\u0629"
    },
    "is_active": {
      "type": "boolean",
      "title": "\u0646\u0634\u0637",
      "default": true
    },
    "permissions": {
      "type": "object",
      "title": "\u0627\u0644\u0635\u0644\u0627\u062d\u064a\u0627\u062a"
    }
  },
  "required": [
    "role",
    "branch_id",
    "branch_name",
    "department",
    "permissions"
  ],
  "rls": {
    "read": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "id": "{{user.id}}"
        }
      ]
    },
    "update": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "id": "{{user.id}}"
        }
      ]
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}