    "branch_name": {
      "type": "string",
      "title": "\u0627\u0633\u0645 \u0627\u0644\u0641\u0631\u0639"
    },
    "period": {
      "type": "string",
      "title": "\u0627\u0644\u0641\u062a\u0631\u0629 (\u0634\u0647\u0631/\u0633\u0646\u0629)"
    },
    "notes": {
      "type": "string",
