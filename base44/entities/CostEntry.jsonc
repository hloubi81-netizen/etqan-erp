    },
    "cost_type": {
      "type": "string",
      "enum": [
        "\u0645\u0648\u0627\u062f \u0645\u0628\u0627\u0634\u0631\u0629",
        "\u0639\u0645\u0627\u0644\u0629 \u0645\u0628\u0627\u0634\u0631\u0629",
        "\u062a\u0643\u0627\u0644\u064a\u0641 \u0635\u0646\u0627\u0639\u064a\u0629 \u063a\u064a\u0631 \u0645\u0628\u0627\u0634\u0631\u0629",
        "\u0645\u0635\u0631\u0648\u0641\u0627\u062a \u0625\u062f\u0627\u0631\u064a\u0629",
        "\u0645\u0635\u0631\u0648\u0641\u0627\u062a \u0628\u064a\u0639",
        "\u0645\u0635\u0631\u0648\u0641\u0627\u062a \u0645\u0627\u0644\u064a\u0629",
        "\u0623\u062e\u0631\u0649"
      ],
      "title": "\u0646\u0648\u0639 \u0627\u0644\u062a\u0643\u0644\u0641\u0629"
    },
