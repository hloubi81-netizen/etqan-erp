{
  "name": "JournalEntry",
  "type": "object",
  "properties": {
    "entry_number": {
      "type": "string",
      "title": "\u0631\u0642\u0645 \u0627\u0644\u0642\u064a\u062f"
    },
    "date": {
      "type": "string",
      "format": "date",
      "title": "\u0627\u0644\u062a\u0627\u0631\u064a\u062e"
    },
    "source_type": {
      "type": "string",
      "enum": [
        "\u0641\u0627\u062a\u0648\u0631\u0629",
        "\u0633\u0646\u062f \u0642\u0628\u0636",
        "\u0633\u0646\u062f \u062f\u0641\u0639",
        "\u0633\u0646\u062f \u064a\u0648\u0645\u064a\u0629",
        "\u0633\u0646\u062f \u0642\u064a\u062f",
        "\u0633\u0646\u062f \u0642\u064a\u062f \u0627\u0641\u062a\u062a\u0627\u062d\u064a",
        "\u0645\u0646\u0627\u0642\u0644\u0629"
      ],
      "title": "\u0646\u0648\u0639 \u0627\u0644\u0645\u0635\u062f\u0631"
    },
    "source_id": {
      "type": "string",
      "title": "\u0645\u0639\u0631\u0641 \u0627\u0644\u0645\u0635\u062f\u0631"
    },
    "source_number": {
      "type": "string",
      "title": "\u0631\u0642\u0645 \u0627\u0644\u0645\u0635\u062f\u0631"
    },
    "debit_account_id": {
      "type": "string",
      "title": "\u0627\u0644\u062d\u0633\u0627\u0628 \u0627\u0644\u0645\u062f\u064a\u0646"
    },
    "debit_account_name": {
      "type": "string",
      "title": "\u0627\u0633\u0645 \u0627\u0644\u062d\u0633\u0627\u0628 \u0627\u0644\u0645\u062f\u064a\u0646"
    },
    "credit_account_id": {
      "type": "string",
      "title": "\u0627\u0644\u062d\u0633\u0627\u0628 \u0627\u0644\u062f\u0627\u0626\u0646"
    },
    "credit_account_name": {
      "type": "string",
      "title": "\u0627\u0633\u0645 \u0627\u0644\u062d\u0633\u0627\u0628 \u0627\u0644\u062f\u0627\u0626\u0646"
    },
    "amount": {
      "type": "number",
      "title": "\u0627\u0644\u0645\u0628\u0644\u063a"
    },
    "currency": {
      "type": "string",
      "title": "\u0627\u0644\u0639\u0645\u0644\u0629"
    },
    "notes": {
      "type": "string",
      "title": "\u0627\u0644\u0628\u064a\u0627\u0646"
    },
    "subscription_id": {
      "type": "string",
      "title": "\u0645\u0639\u0631\u0641 \u0627\u0644\u0627\u0634\u062a\u0631\u0627\u0643"
    },
    "cost_center_id": {
      "type": "string",
      "title": "\u0645\u0631\u0643\u0632 \u0627\u0644\u0643\u0644\u0641\u0629"
    }
  },
  "required": [
    "date",
    "amount"
  ],
  "rls": {
    "create": {
      "data.subscription_id": "{{user.subscription_id}}"
    },
    "read": {
      "data.subscription_id": "{{user.subscription_id}}"
    },
    "update": {
      "data.subscription_id": "{{user.subscription_id}}"
    },
    "delete": {
      "$and": [
        {
          "data.subscription_id": "{{user.subscription_id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}