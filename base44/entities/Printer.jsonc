{
  "name": "Printer",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "title": "\u0627\u0633\u0645 \u0627\u0644\u0637\u0627\u0628\u0639\u0629"
    },
    "ip_address": {
      "type": "string",
      "title": "\u0639\u0646\u0648\u0627\u0646 IP"
    },
    "port": {
      "type": "number",
      "title": "\u0627\u0644\u0645\u0646\u0641\u0630 (Port)",
      "default": 9100
    },
    "department": {
      "type": "string",
      "title": "\u0627\u0644\u0642\u0633\u0645"
    },
    "is_main": {
      "type": "boolean",
      "title": "\u0637\u0627\u0628\u0639\u0629 \u0631\u0626\u064a\u0633\u064a\u0629 (\u0625\u064a\u0635\u0627\u0644 \u0627\u0644\u0639\u0645\u064a\u0644)",
      "default": false
    },
    "is_active": {
      "type": "boolean",
      "title": "\u0645\u0641\u0639\u0644\u0629",
      "default": true
    },
    "notes": {
      "type": "string",
      "title": "\u0645\u0644\u0627\u062d\u0638\u0627\u062a"
    }
  },
  "required": [
    "name",
    "ip_address",
    "department"
  ],
  "rls": {
    "create": {
      "created_by_id": "{{user.id}}"
    },
    "read": {
      "created_by_id": "{{user.id}}"
    },
    "update": {
      "created_by_id": "{{user.id}}"
    },
    "delete": {
      "created_by_id": "{{user.id}}"
    }
  }
}