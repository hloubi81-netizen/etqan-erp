{
  "name": "Currency",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "title": "\u0627\u0633\u0645 \u0627\u0644\u0639\u0645\u0644\u0629"
    },
    "symbol": {
      "type": "string",
      "title": "\u0631\u0645\u0632 \u0627\u0644\u0639\u0645\u0644\u0629"
    },
    "unit_name": {
      "type": "string",
      "title": "\u0627\u0644\u0648\u062d\u062f\u0629"
    },
    "sub_unit": {
      "type": "string",
      "title": "\u062c\u0632\u0621 \u0627\u0644\u0639\u0645\u0644\u0629"
    },
    "exchange_rate": {
      "type": "number",
      "title": "\u0633\u0639\u0631 \u0627\u0644\u062a\u0639\u0627\u062f\u0644"
    },
    "is_local": {
      "type": "boolean",
      "title": "\u0639\u0645\u0644\u0629 \u0645\u062d\u0644\u064a\u0629"
    },
    "description": {
      "type": "string",
      "title": "\u0627\u0644\u0648\u0635\u0641",
      "maxLength": 1000
    }
  },
  "required": [
    "name",
    "symbol"
  ],
  "rls": {
    "create": {
      "created_by_id": "{{user.id}}"
    },
    "read": {
      "created_by_id": "{{user.id}}"
    },
    "update": {
      "created_by_id": "{{user.id}}"
    },
