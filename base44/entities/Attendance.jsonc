{
  "name": "Attendance",
  "type": "object",
  "properties": {
    "employee_id": {
      "type": "string",
      "title": "\u0627\u0644\u0645\u0648\u0638\u0641"
    },
    "employee_name": {
      "type": "string",
      "title": "\u0627\u0633\u0645 \u0627\u0644\u0645\u0648\u0638\u0641"
    },
    "date": {
      "type": "string",
      "format": "date",
      "title": "\u0627\u0644\u062a\u0627\u0631\u064a\u062e"
    },
    "type": {
      "type": "string",
      "enum": [
        "\u062d\u0636\u0648\u0631",
        "\u063a\u064a\u0627\u0628",
        "\u0625\u062c\u0627\u0632\u0629",
        "\u0625\u062c\u0627\u0632\u0629 \u0645\u0631\u0636\u064a\u0629",
        "\u062a\u0623\u062e\u064a\u0631"
      ],
      "title": "\u0627\u0644\u0646\u0648\u0639"
    },
    "check_in": {
      "type": "string",
      "title": "\u0648\u0642\u062a \u0627\u0644\u062f\u062e\u0648\u0644"
    },
    "check_out": {
      "type": "string",
      "title": "\u0648\u0642\u062a \u0627\u0644\u062e\u0631\u0648\u062c"
    },
    "hours": {
      "type": "number",
      "title": "\u0633\u0627\u0639\u0627\u062a \u0627\u0644\u0639\u0645\u0644"
    },
    "branch_id": {
      "type": "string",
      "title": "\u0627\u0644\u0641\u0631\u0639"
    },
    "branch_name": {
      "type": "string",
      "title": "\u0627\u0633\u0645 \u0627\u0644\u0641\u0631\u0639"
    },
    "subscription_id": {
      "type": "string",
      "title": "\u0645\u0639\u0631\u0641 \u0627\u0644\u0627\u0634\u062a\u0631\u0627\u0643"
    },
    "notes": {
      "type": "string",
      "title": "\u0645\u0644\u0627\u062d\u0638\u0627\u062a"
    }
  },
  "required": [
    "employee_id",
    "date",
    "type"
  ],
  "rls": {
    "create": {
      "data.subscription_id": "{{user.subscription_id}}"
    },
    "read": {
      "data.subscription_id": "{{user.subscription_id}}"
    },
    "update": {
      "data.subscription_id": "{{user.subscription_id}}"
    },
    "delete": {
      "$and": [
        {
          "data.subscription_id": "{{user.subscription_id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}