{
  "name": "StockTransfer",
  "type": "object",
  "properties": {
    "transfer_number": {
      "type": "string",
      "title": "\u0631\u0642\u0645 \u0627\u0644\u0645\u0646\u0627\u0642\u0644\u0629"
    },
    "date": {
      "type": "string",
      "format": "date",
      "title": "\u0627\u0644\u062a\u0627\u0631\u064a\u062e"
    },
    "from_warehouse_id": {
      "type": "string",
      "title": "\u0645\u0646 \u0627\u0644\u0645\u0633\u062a\u0648\u062f\u0639"
    },
    "from_warehouse_name": {
      "type": "string",
      "title": "\u0627\u0633\u0645 \u0627\u0644\u0645\u0633\u062a\u0648\u062f\u0639 \u0627\u0644\u0645\u0635\u062f\u0631"
    },
    "from_branch_id": {
      "type": "string",
      "title": "\u0645\u0646 \u0627\u0644\u0641\u0631\u0639"
    },
    "from_branch_name": {
      "type": "string",
      "title": "\u0627\u0633\u0645 \u0627\u0644\u0641\u0631\u0639 \u0627\u0644\u0645\u0635\u062f\u0631"
    },
    "to_warehouse_id": {
      "type": "string",
      "title": "\u0625\u0644\u0649 \u0627\u0644\u0645\u0633\u062a\u0648\u062f\u0639"
    },
    "to_warehouse_name": {
      "type": "string",
      "title": "\u0627\u0633\u0645 \u0627\u0644\u0645\u0633\u062a\u0648\u062f\u0639 \u0627\u0644\u0647\u062f\u0641"
    },
    "to_branch_id": {
      "type": "string",
      "title": "\u0625\u0644\u0649 \u0627\u0644\u0641\u0631\u0639"
    },
    "to_branch_name": {
      "type": "string",
      "title": "\u0627\u0633\u0645 \u0627\u0644\u0641\u0631\u0639 \u0627\u0644\u0647\u062f\u0641"
    },
    "status": {
      "type": "string",
      "enum": [
        "\u0645\u0633\u0648\u062f\u0629",
        "\u0645\u0639\u062a\u0645\u062f",
        "\u0645\u0643\u062a\u0645\u0644",
        "\u0645\u0644\u063a\u0649"
      ],
      "default": "\u0645\u0633\u0648\u062f\u0629",
      "title": "\u0627\u0644\u062d\u0627\u0644\u0629"
    },
    "notes": {
      "type": "string",
      "title": "\u0627\u0644\u0628\u064a\u0627\u0646"
    },
    "subscription_id": {
      "type": "string",
      "title": "\u0645\u0639\u0631\u0641 \u0627\u0644\u0627\u0634\u062a\u0631\u0627\u0643"
    },
    "items": {
      "type": "array",
      "title": "\u0627\u0644\u0645\u0648\u0627\u062f",
      "items": {
        "type": "object",
        "properties": {
          "product_id": {
            "type": "string"
          },
          "product_name": {
            "type": "string"
          },
          "quantity": {
            "type": "number"
          },
          "unit": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  },
  "required": [
    "transfer_number",
    "date",
    "from_warehouse_id",
    "to_warehouse_id"
  ],
  "rls": {
    "create": {
      "data.subscription_id": "{{user.subscription_id}}"
    },
    "read": {
      "data.subscription_id": "{{user.subscription_id}}"
    },
    "update": {
      "data.subscription_id": "{{user.subscription_id}}"
    },
    "delete": {
      "$and": [
        {
          "data.subscription_id": "{{user.subscription_id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}