{
  "name": "LeaveRequest",
  "type": "object",
  "properties": {
    "employee_id": {
      "type": "string",
      "title": "\u0627\u0644\u0645\u0648\u0638\u0641"
    },
    "employee_name": {
      "type": "string",
      "title": "\u0627\u0633\u0645 \u0627\u0644\u0645\u0648\u0638\u0641"
    },
    "leave_type": {
      "type": "string",
      "enum": [
        "\u0633\u0646\u0648\u064a\u0629",
        "\u0645\u0631\u0636\u064a\u0629",
        "\u0637\u0627\u0631\u0626\u0629",
        "\u0623\u0645\u0648\u0645\u0629/\u0623\u0628\u0648\u0629",
        "\u0628\u062f\u0648\u0646 \u0631\u0627\u062a\u0628"
      ],
      "title": "\u0646\u0648\u0639 \u0627\u0644\u0625\u062c\u0627\u0632\u0629"
    },
    "start_date": {
      "type": "string",
      "format": "date",
      "title": "\u062a\u0627\u0631\u064a\u062e \u0627\u0644\u0628\u062f\u0627\u064a\u0629"
    },
    "end_date": {
      "type": "string",
      "format": "date",
      "title": "\u062a\u0627\u0631\u064a\u062e \u0627\u0644\u0646\u0647\u0627\u064a\u0629"
    },
    "days": {
      "type": "number",
      "title": "\u0639\u062f\u062f \u0627\u0644\u0623\u064a\u0627\u0645"
    },
    "reason": {
      "type": "string",
      "title": "\u0627\u0644\u0633\u0628\u0628"
    },
    "status": {
      "type": "string",
      "enum": [
        "\u0645\u0639\u0644\u0642\u0629",
        "\u0645\u0648\u0627\u0641\u0642 \u0639\u0644\u064a\u0647\u0627",
        "\u0645\u0631\u0641\u0648\u0636\u0629"
      ],
      "default": "\u0645\u0639\u0644\u0642\u0629",
      "title": "\u0627\u0644\u062d\u0627\u0644\u0629"
    },
    "notes": {
      "type": "string",
      "title": "\u0645\u0644\u0627\u062d\u0638\u0627\u062a \u0627\u0644\u0645\u062f\u064a\u0631"
    }
  },
  "required": [
    "employee_id",
    "leave_type",
    "start_date",
    "end_date"
  ],
  "rls": {
    "create": {
      "created_by_id": "{{user.id}}"
    },
    "read": {
      "created_by_id": "{{user.id}}"
    },
    "update": {
      "created_by_id": "{{user.id}}"
    },
    "delete": {
      "created_by_id": "{{user.id}}"
    }
  }
}